# Copy to .env and adjust. Restart Vite after changes.

# Optional: public contact block (defaults match FarmyCure placeholders)
# VITE_CONTACT_LOCATION_LABEL=Andhra Pradesh, India
# VITE_CONTACT_MAPS_URL=https://www.google.com/maps/search/?api=1&query=Your+City
# VITE_CONTACT_PHONE_DISPLAY=+91 98765 43210
# VITE_CONTACT_PHONE_TEL=+919876543210
# VITE_CONTACT_EMAIL=support@farmycure.com
# VITE_CONTACT_INSTAGRAM_URL=https://www.instagram.com/yourhandle
# VITE_CONTACT_LINKEDIN_URL=https://www.linkedin.com/company/yourcompany

# Production API URL
# VITE_API_URL=https://api.farmycure.com

# Razorpay public key (required for checkout)
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
